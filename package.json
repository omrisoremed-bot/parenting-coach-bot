{
  "name": "parentatease",
  "version": "1.1.0",
  "description": "ParentAtEase — AI parenting coach on WhatsApp + Telegram + Web. Daily personalized guidance powered by OpenAI-compatible LLMs.",
  "main": "bot.js",
  "scripts": {
    "start": "node bot.js",
    "postinstall": "node scripts/build-knowledge-cache.js || echo 'knowledge cache build skipped'",
    "dev": "nodemon bot.js",
    "migrate": "node scripts/migrate-json-to-sqlite.js",
    "db:migrate-volume": "node scripts/migrate-db-to-volume.js",
    "backup:sqlite": "node scripts/backup-sqlite.js",
    "article": "node scripts/generate-article.js",
    "social": "node scripts/article-to-social.js",
    "weekly": "node scripts/weekly-content.js",
    "knowledge:build": "node scripts/build-knowledge-cache.js",
    "seo:sitemap": "node scripts/generate-sitemap.js",
    "seo:jsonld": "node scripts/inject-jsonld.js",
    "seo:all": "npm run seo:jsonld && npm run seo:sitemap",
    "security:check-leaks": "node scripts/check-key-leaks.js",
    "test": "node --test \"tests/**/*.test.js\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "axios": "^1.7.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^8.3.2",
    "form-data": "^4.0.0",
    "grammy": "^1.42.0",
    "helmet": "^8.1.0",
    "node-cron": "^3.0.3",
    "openai": "^4.104.0",
    "pdf-parse": "^2.4.5",
    "stripe": "^22.1.1",
    "twilio": "^5.3.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "localtunnel": "^2.0.2",
    "nodemon": "^3.1.0"
  }
}
