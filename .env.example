# ─── WhatsApp Provider: 'meta' or 'twilio' ───────────────────────────────────
PROVIDER=meta

# ─── Meta Cloud API ───────────────────────────────────────────────────────────
META_ACCESS_TOKEN=your_permanent_system_user_token
PHONE_NUMBER_ID=your_phone_number_id
VERIFY_TOKEN=your_random_verify_string_min_16_chars
# App Secret → Meta Developer Console → Ton App → Paramètres → Infos générales → App Secret
# Requis pour la vérification HMAC-SHA256 des webhooks (sécurité anti-spoofing)
META_APP_SECRET=your_meta_app_secret

# ─── Twilio (used when PROVIDER=twilio) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886
# URL publique complète du webhook (ex: https://ton-app.railway.app/webhook)
# Requis pour la vérification de signature Twilio (sécurité anti-spoofing)
TWILIO_WEBHOOK_URL=https://your-domain.railway.app/webhook

# ─── AI — NVIDIA NIM (FREE, 1000 credits/month) ──────────────────────────────
# Get your free key at: https://build.nvidia.com  → "Get API Key"
AI_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_MODEL=meta/llama-3.1-8b-instruct

# ─── Alternative free providers (same OpenAI-compatible format) ──────────────
# Groq (14 400 req/day — fastest)  → https://console.groq.com
#   AI_BASE_URL=https://api.groq.com/openai/v1
#   AI_MODEL=llama-3.3-70b-versatile

# OpenRouter (many free models)    → https://openrouter.ai
#   AI_BASE_URL=https://openrouter.ai/api/v1
#   AI_MODEL=mistralai/mistral-7b-instruct:free

# Together AI (free credits)       → https://api.together.xyz
#   AI_BASE_URL=https://api.together.xyz/v1
#   AI_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# ─── Telegram Bot (optional — enables Telegram channel in parallel to WhatsApp) ─
# Create a bot with @BotFather → /newbot → copy the token here.
# Once set, POST webhook URL to:
#   https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://<your-domain>/webhook/telegram
TELEGRAM_BOT_TOKEN=

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=9000
NODE_ENV=production
TIMEZONE=Africa/Casablanca
LOG_LEVEL=info
# Origine autorisée pour les appels /api depuis la webapp (CORS)
# Ex: https://ton-app.railway.app — laisser vide pour désactiver CORS en dev
WEBAPP_ORIGIN=https://your-domain.railway.app

# ─── Admin ───────────────────────────────────────────────────────────────────
# Protects /admin endpoints — set a long random string
ADMIN_TOKEN=change_me_to_a_strong_random_token

# ─── Fal.ai — Génération d'images (Phase 4b, optionnel) ──────────────────────
# Génère automatiquement les visuels lors de `npm run social`
# Obtenir une clé sur https://fal.ai/dashboard → API Keys
FAL_API_KEY=

# ─── Transcription audio Twilio (optionnel) ───────────────────────────────────
# Active la transcription vocale via Groq Whisper (notes vocales WhatsApp)
# Obtenir une clé gratuite sur https://console.groq.com
GROQ_API_KEY=

# ─── WhatsApp Sandbox Twilio (optionnel) ──────────────────────────────────────
# Code de jonction affiché dans le message d'aide aux utilisateurs Twilio sandbox
SANDBOX_JOIN_CODE=join on-help
